{
  "manifest_version": 3,
  "name": "FormAssist",
  "description": "KI-Formularassistent für Webseiten",
  "version": "1.0",
  "icons": {
    "128": "icon128.svg"
  },
  "action": {
    "default_title": "FormAssist"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["state.js", "ui.js", "api.js", "bootstrap.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["api-key.txt"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
