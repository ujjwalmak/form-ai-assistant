{
  "manifest_version": 3,
  "name": "FormAssist – KI Formular-Assistent",
  "description": "KI-gestützter Assistent für jedes Online-Formular",
  "version": "1.0",
  "icons": { "128": "icon.svg" },
  "action": { "default_title": "FormAssist", "default_icon": { "128": "icon.svg" } },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage"],
  "host_permissions": ["https://api.groq.com/*"],
  "web_accessible_resources": [
    {
      "resources": ["api-key.txt"],
      "matches": ["<all_urls>"]
    }
  ]
}
